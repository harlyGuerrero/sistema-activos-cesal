            {/* BOTON PRINCIPAL */}

            <Button
              type="submit"
              className="
                h-14
                w-full
                rounded-2xl
                bg-blue-700
                text-lg
                font-semibold
                shadow-lg
                hover:bg-blue-800
              "
            >
              Confirmar Alta
            </Button>

            {/* CANCELAR */}

            <Button
              type="button"
              variant="ghost"
              onClick={onClose}
              className="
                h-auto
                w-full
                text-lg
                text-slate-600
                underline
                hover:bg-transparent
              "
            >
              Cancelar
            </Button>
          </form>
        </div>

        {/* FOOTER */}

        <div className="border-t border-slate-200 bg-slate-100 px-8 py-4 dark:bg-slate-950 dark:border-slate-700">
          <p className="text-sm text-slate-500">
            ℹ Esta acción será registrada en la bitácora de auditoría.
          </p>
        </div>
      </DialogContent>
    </Dialog>
  );
}
