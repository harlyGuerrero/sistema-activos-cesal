} from "../types/activo-detalle.type";

import type {
  AssetStatus,
} from "../constants/asset-status";

function mapEstado(
  estado: string,
): AssetStatus {

  switch (estado.toLowerCase()) {

    case "operativo":
      return "Disponible";

    default:
      return estado as AssetStatus;

  }

}

export function mapActivoDetalle(

  activo: ActivoDetalleApi,

): ActivoDetalle {

  return {

    id: activo.idActivo,

    tipoActivoId:
      activo.idTipoActivo,

    nombre:
      activo.nombreActivo,

    codigoPatrimonial:
      activo.codigoPatrimonial,

    codigoProyecto:
      activo.codigoProyecto,

    codigoProveedor:
      activo.codigoProveedor,

    numeroFactura:
      activo.numeroFactura,

    categoria:
      activo.tipoActivo,

    estado:
      mapEstado(
        activo.estadoActivo,
      ),

    costo:
      activo.costo,

    fechaAdquisicion:
      new Date(
        activo.fechaAdquisicion,
      ).toLocaleDateString("es-PE"),

    ambiente:
      activo.ambiente,

    sede:
      activo.sede,

    zona:
      activo.zona,

    unidadOperativa:
